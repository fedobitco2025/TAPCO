# ================================================
# TAPCO Backend — Environment Variables Example
# ================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ================================================

PORT=4000
NODE_ENV=production

# CORS allowed origins (comma-separated)
# Example: https://tapco.app,https://www.tapco.app
CORS_ORIGINS=

# MongoDB (when running locally without Docker)
MONGO_URI=mongodb://localhost:27017/tapco_game
# MongoDB (auto-set by docker-compose to internal service name)
# MONGODB_URI=mongodb://mongo:27017/tapco_game

# Security — MUST match TAPCO_CLIENT_SECRET in Game.html
REQUEST_SECRET=TAPCO_CLIENT_SECRET_2024
JWT_SECRET=change_me_to_a_long_random_string

# Blockchain (BNB Chain)
RPC_URL=https://YOUR_RPC_ENDPOINT
PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY
CONTRACT_ADDRESS=YOUR_TAPCO_CONTRACT_ADDRESS

# Rate Limiting
USER_RATE_WINDOW_MS=1000
USER_RATE_LIMIT=5
IP_THROTTLE_WINDOW_MS=1000
IP_THROTTLE_LIMIT=20

# Session
SESSION_TTL_MS=86400000
SESSION_REPLAY_WINDOW_MS=10000
SESSION_RECENT_REQUEST_LIMIT=20
NONCE_TTL_SECONDS=86400

# Withdrawal Worker
WORKER_INTERVAL_MS=15000
WORKER_BATCH_SIZE=5
WITHDRAW_MIN_AMOUNT=25
DAILY_WITHDRAW_LIMIT=1000
WEEKLY_WITHDRAW_LIMIT=5000
INITIAL_PLAYER_BALANCE=0

# ================================================
# 🔒 ADVANCED SECURITY SETTINGS (Military-Grade)
# ================================================

# Encryption for sensitive data
ENCRYPTION_KEY=your_256_bit_encryption_key_here

# Brute Force Detection
BRUTE_FORCE_THRESHOLD=5
BRUTE_FORCE_WINDOW_MS=900000
BRUTE_FORCE_LOCKOUT_MS=1800000

# OTP (One-Time Password) Settings
OTP_EXPIRY_MS=300000
OTP_MAX_ATTEMPTS=3
# Show dev OTP in API response (must be false in production)
EXPOSE_DEV_OTP=false

# IP Reputation Tracking
SUSPICIOUS_IP_THRESHOLD=100
IP_ACTIVITY_WINDOW_MS=86400000

# 2-Factor Authentication for Large Withdrawals
WITHDRAWAL_2FA_THRESHOLD=10000
LARGE_WITHDRAWAL_DAILY_LIMIT=25000

# IP Whitelist (comma-separated) - for sensitive operations only
IP_WHITELIST=127.0.0.1,::1

# Security Features Toggle
ENABLE_2FA=true
ENABLE_IP_REPUTATION=true
ENABLE_LOCATION_ANOMALY_DETECTION=true

# Telegram Closed Beta Gate (optional)
# Set to true to allow only specific Telegram users to access API routes
TELEGRAM_BETA_GATE_ENABLED=false
# Comma-separated Telegram numeric user IDs allowed during closed beta
# Example: TELEGRAM_BETA_ALLOWLIST=123456789,987654321
TELEGRAM_BETA_ALLOWLIST=
# Message shown to blocked users
TELEGRAM_BETA_BLOCK_MESSAGE=The game is currently in closed beta.

# Audit Logging
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=90

# Runtime Security Alerts (stdout + security logs)
SECURITY_ALERT_WINDOW_MS=60000
RATE_LIMIT_ALERT_THRESHOLD=25
OTP_FAILURE_ALERT_THRESHOLD=10
WORKER_FAILURE_ALERT_THRESHOLD=5

